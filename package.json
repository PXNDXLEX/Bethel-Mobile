{
  "name": "repo",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "node increment-version.cjs && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "node increment-version.cjs && vite build && electron-builder --win nsis",
    "build:apk": "node increment-version.cjs && npx cap copy && cd android && gradlew assembleRelease && copy app\\build\\outputs\\apk\\release\\app-release-unsigned.apk ..\\Bethel.apk"
  },
  "build": {
    "appId": "com.dulcebethel.app",
    "productName": "Bethel",
    "icon": "icon.png",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capgo/capacitor-native-biometric": "^8.4.5",
    "@supabase/supabase-js": "^2.107.0"
  }
}